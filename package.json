{
  "name": "sysmonitor",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.0.0",
  "publisher": "lichenxi",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lcx-0504/sysmonitor.git"
  },
  "engines": { "vscode": "^1.70.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sysmonitor-container",
          "title": "%viewTitle%",
          "icon": "./icon.svg"
        }
      ]
    },
    "views": {
      "sysmonitor-container": [
        {
          "type": "webview",
          "id": "sysmonitor.panel",
          "name": "%viewName%"
        }
      ]
    },
    "commands": [
      {
        "command": "sysmonitor.openPanel",
        "title": "%cmdOpen%"
      }
    ],
    "configuration": {
      "title": "System Monitor",
      "properties": {
        "sysmonitor.refreshInterval": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 30,
          "description": "Refresh interval in seconds"
        },
        "sysmonitor.statusBar.remote": {
          "type": "object",
          "default": {
            "cpu": true,
            "ram": false,
            "net": "off",
            "ssh": false,
            "gpu": { "summary": true, "mode": "off", "cards": [], "metric": "both" }
          },
          "description": "Status bar items when connected via SSH"
        },
        "sysmonitor.statusBar.local": {
          "type": "object",
          "default": {
            "cpu": true,
            "ram": false,
            "net": "off",
            "gpu": { "summary": false, "mode": "off", "cards": [], "metric": "both" }
          },
          "description": "Status bar items for local use"
        }
      }
    }
  }
}
